# Next.js static export routing for Apache
# public/.htaccess → out/.htaccess → FTP → www.auvita.tw 根目錄

RewriteEngine On

# 非 www → www 301 redirect（canonical domain 統一為 www.auvita.tw）
RewriteCond %{HTTP_HOST} !^www\. [NC]
RewriteRule ^ https://www.%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

# 關掉 mod_dir 自動加結尾斜線（避免 /zh-TW 死循環）
DirectorySlash Off

# 預設語系：根路徑 / → /zh-TW（301 永久重定向）
RewriteRule ^$ /zh-TW [R=301,L]

# 移除結尾斜線（/zh-TW/ → /zh-TW）
RewriteRule ^(.+)/$ /$1 [R=301,L]

# 無副檔名請求 → .html（Next.js static export 格式）
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{DOCUMENT_ROOT}/$1.html -f
RewriteRule ^(.+)$ /$1.html [L]

# 自訂 404
ErrorDocument 404 /404.html

# 禁止目錄列出
Options -Indexes

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/jpeg "access plus 30 days"
  ExpiresByType image/png "access plus 30 days"
  ExpiresByType image/webp "access plus 30 days"
  ExpiresByType image/svg+xml "access plus 30 days"
  ExpiresByType text/css "access plus 7 days"
  ExpiresByType application/javascript "access plus 7 days"
  ExpiresByType text/html "access plus 0 seconds"
</IfModule>

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json text/plain
</IfModule>

# ── 安全標頭（SEO H1）────────────────────────────────────────────────────
<IfModule mod_headers.c>
  # HSTS：瀏覽器強制走 HTTPS，1 年
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

  # Clickjacking 防護
  Header always set X-Frame-Options "SAMEORIGIN"

  # 阻止 MIME 嗅探
  Header always set X-Content-Type-Options "nosniff"

  # Referrer 控制：同源完整 URL，跨源只傳 origin
  Header always set Referrer-Policy "strict-origin-when-cross-origin"

  # 禁用不必要的瀏覽器 API
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()"

  # CSP：Report-Only 模式觀察（避免影響 GA/GTM；改 enforce 前先看 report）
  Header always set Content-Security-Policy-Report-Only "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://www.google-analytics.com https://www.googletagmanager.com https://www.google.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self' https://www.google-analytics.com https://analytics.google.com; frame-src 'none'; object-src 'none'"
</IfModule>
